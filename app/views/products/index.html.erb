<h2>All Products</h2>

<%= link_to 'New Product', new_product_path, class: 'btn btn-primary mb-3' %>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Name</th>
      <th>Image</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @products.each do |product| %>
      <tr>
        <td><%= product.name %></td>
        <td><%= image_tag product.image, width: 100 if product.image.attached? %></td>
        <td>
          <%= link_to 'Show', product, class: 'btn btn-info btn-sm' %>
          <%= link_to 'Edit', edit_product_path(product), class: 'btn btn-warning btn-sm' %>
          <%= button_to 'Delete', product_path(product), method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn btn-danger btn-sm', form: { class: 'd-inline' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
