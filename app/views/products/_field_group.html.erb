<div class="row align-items-end mb-2" data-field>
  <div class="col">
    <%= f.label :key, class: 'form-label' %>
    <%= f.text_field :key, class: 'form-control' %>
  </div>

  <div class="col">
    <%= f.label :value, class: 'form-label' %>
    <%= f.text_field :value, class: 'form-control' %>
  </div>

  <div class="col-auto">
    <%= link_to 'Remove', '#', class: 'btn btn-danger btn-sm', data: { remove: true } %>
  </div>

  <%= f.hidden_field :_destroy %>
</div>
